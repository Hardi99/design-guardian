    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.7"
  }
}
