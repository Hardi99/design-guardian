{
  "name": "design-guardian-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "build-figma-plugin --typecheck",
    "watch": "build-figma-plugin --typecheck --watch",
    "typecheck": "tsc --noEmit"
  },
  "figma-plugin": {
    "name": "Design Guardian",
    "id": "design-guardian-dev",
    "api": "1.0.0",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "editorType": [
      "figma"
    ],
    "networkAccess": {
      "allowedDomains": [
        "https://design-guardian.up.railway.app",
        "http://localhost:3000"
      ]
    }
  },
  "dependencies": {
    "@create-figma-plugin/utilities": "^3.0.0",
    "preact": "^10.24.0"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^3.0.0",
    "@figma/plugin-typings": "^1.101.0",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0"
  }
}
