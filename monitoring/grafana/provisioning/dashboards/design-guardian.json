{
  "title": "Design Guardian — API",
  "uid": "dg-api",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes / seconde",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_total{app=\"design-guardian\"}[1m])",
        "legendFormat": "{{method}} {{route}} {{status}}"
      }]
    },
    {
      "id": 2,
      "title": "Latence p95 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket{app=\"design-guardian\"}[5m]))",
        "legendFormat": "p95 {{route}}"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      }
    },
    {
      "id": 3,
      "title": "Checkpoints créés (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "checkpoints_created_total{app=\"design-guardian\"}",
        "legendFormat": "Checkpoints"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": 0 }] } } }
    },
    {
      "id": 4,
      "title": "AI Patch Notes générés",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "ai_summaries_generated_total{app=\"design-guardian\",status=\"success\"}",
        "legendFormat": "AI summaries"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 5,
      "title": "Connexions actives",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "active_connections{app=\"design-guardian\"}",
        "legendFormat": "Connexions"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "id": 7,
      "title": "Taux d'erreurs HTTP 5xx",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_total{app=\"design-guardian\",status=~\"5..\"}[5m])",
        "legendFormat": "5xx"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.01 }] },
          "custom": { "thresholdsStyle": { "mode": "area" } }
        }
      }
    },
    {
      "id": 8,
      "title": "Paiements Stripe (événements)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "increase(payments_total{app=\"design-guardian\"}[1h])",
        "legendFormat": "{{event}} / {{plan}}"
      }]
    },
    {
      "id": 9,
      "title": "Abonnements actifs (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 7 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(payments_total{app=\"design-guardian\",event=\"subscription_started\"}[30d])) - sum(increase(payments_total{app=\"design-guardian\",event=\"subscription_cancelled\"}[30d]))",
        "legendFormat": "Abonnements nets"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 10,
      "title": "SLA — Disponibilité (%) sur 1h",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 7 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * (1 - rate(http_requests_total{app=\"design-guardian\",status=~\"5..\"}[1h]) / rate(http_requests_total{app=\"design-guardian\"}[1h]))",
        "legendFormat": "SLA %"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 95, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 95  },
              { "color": "yellow", "value": 99  },
              { "color": "green",  "value": 99.5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true }
    }
  ]
}
